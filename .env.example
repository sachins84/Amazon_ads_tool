# Amazon Ads API — required (or app runs in Demo Mode)
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=
AMAZON_PROFILE_ID=
AMAZON_API_ENDPOINT=https://advertising-api.amazon.com  # FE: -fe.amazon.com, EU: -eu.amazon.com
CACHE_TTL=300

# Required — used to encrypt OAuth tokens at rest in SQLite.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Treat like a database password — losing it means existing encrypted rows can't be decrypted.
ENCRYPTION_SECRET=

# Daily refresh cron (in-process, runs inside the PM2 process)
REFRESH_CRON=30 2 * * *   # UTC; default = 8 AM IST
REFRESH_DAYS=14           # trailing-window size
# DISABLE_CRON=1          # set on staging / any next start where you don't want the cron to fire
# ENABLE_CRON_IN_DEV=1    # only set for local `next dev` testing
